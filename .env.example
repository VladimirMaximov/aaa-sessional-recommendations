# Copy to `.env` and fill in values.

# --- Application ---
REDIS_URL=redis://localhost:6379/0
SESSION_TTL_SECONDS=86400

FEED_MAX_GROUPS=2000
EMB_DIM=768

# --- S3 (all data artifacts are read from S3; nothing is stored locally) ---
S3_ENDPOINT_URL=https://s3.endpoint.url
S3_BUCKET=your-bucket-name
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_REGION=ru-1
S3_PRESIGN_TTL_SECONDS=3600

# S3 object keys (within S3_BUCKET) for the data artifacts
FEED_S3_KEY=val/val.parquet
EMB_S3_KEY=embeddings/item_embeddings.parquet
RERANKER_S3_KEY=models/reranker_catboost.cbm

# --- ANN mixing (FAISS OPQ+IVFPQ index loaded from S3 into memory) ---
# S3 object keys for the prebuilt index + ids + full title catalog
FAISS_INDEX_S3_KEY=models/faiss_ivfpq.index
FAISS_IDS_S3_KEY=models/faiss_item_ids.npy
CATALOG_S3_KEY=item_catalog/item_catalog.parquet

# ANN tuning (set ANN_ENABLED=false to disable mixing entirely)
ANN_ENABLED=true
ANN_NPROBE=32
ANN_POOL_N=400
# ANN_EXPLOIT_K — размер ближнего окна соседей: exploit из cand[:K], explore из cand[K:]
ANN_EXPLOIT_K=6
# ANN_EVERY — каждая N-я карточка отдаётся как ANN (тип exploit/explore чередуется)
ANN_EVERY=3
ANN_RECENT_LIKES=5

# --- LLM-as-a-judge ---
ROUTERAI_BASE_URL=https://routerai.ru/api/v1
ROUTERAI_API_KEY=
LLM_JUDGE_MODEL=qwen/qwen3-next-80b-a3b-instruct
